# Google Gemini API Key (used for reverse geocoding only)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ⭐ Groq API Key — PRIMARY LLM provider (30 RPM free, blazing fast)
# Get yours FREE at: https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# GNews API Key (local real estate news)
# Get yours at: https://gnews.io  (free tier: 100 requests/day)
GNEWS_API_KEY=your_gnews_api_key_here

# OpenCage Geocoder API Key (reverse geocoding GPS → city name)
# Get yours at: https://opencagedata.com  (free tier: 2,500 requests/day)
OPENCAGE_API_KEY=your_opencage_api_key_here


# OpenCage Geocoder API Key (reverse geocoding GPS → city name)
# Get yours at: https://opencagedata.com  (free tier: 2,500 requests/day)
OPENCAGE_API_KEY=your_opencage_api_key_here

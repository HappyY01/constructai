{
    "version": 2,
    "builds": [
        {
            "src": "backend/main.py",
            "use": "@vercel/python"
        },
        {
            "src": "frontend/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/generate-plan",
            "dest": "backend/main.py"
        },
        {
            "src": "/modify-plan",
            "dest": "backend/main.py"
        },
        {
            "src": "/news",
            "dest": "backend/main.py"
        },
        {
            "src": "/reverse-geocode",
            "dest": "backend/main.py"
        },
        {
            "src": "/app.js",
            "dest": "frontend/app.js"
        },
        {
            "src": "/styles.css",
            "dest": "frontend/styles.css"
        },
        {
            "src": "/(.*)",
            "dest": "frontend/index.html"
        }
    ]
}